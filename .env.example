PORT=3000
ALLOWED_ORIGINS=http://your-frontend-domain.com

# JWT
ACCESS_TOKEN_SECRET=your_access_token_secret
REFRESH_TOKEN_SECRET=your_refresh_token_secret
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Destroy endpoint ─────────────────────────────────────────────────────────
# A long random secret required to trigger POST /destroy
# Generate with: openssl rand -hex 32
DESTROY_SECRET=your_very_long_random_secret_here

# Absolute path to the root of the deployment (default: auto-detected).
# Set this explicitly on the server so cleanup targets the correct directory.
# Example: DEPLOY_ROOT=/home/ubuntu/nest-hello-app
DEPLOY_ROOT=/home/ubuntu/nest-hello-app

# ── iLovePDF ─────────────────────────────────────────────────────────────────
ILOVEPDF_PUBLIC_KEY=your_ilovepdf_public_key

# ── CloudConvert (DWG/DWF → PDF) ─────────────────────────────────────────────
CLOUDCONVERT_API_KEY=your_cloudconvert_api_key
